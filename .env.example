# Copy this file to .env.local (for local dev) and also add these values in
# Vercel → Project Settings → Environment Variables (for production).
# NEVER commit the real .env.local file. It is already in .gitignore.

# ============================================================
# CLERK — Authentication
# Get at: https://dashboard.clerk.com → your app → API Keys
# ============================================================
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# Clerk redirect URLs — keep these exact
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/dashboard
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/dashboard

# Clerk webhook signing secret — from Clerk Dashboard → Webhooks → your endpoint
CLERK_WEBHOOK_SECRET=whsec_...

# ============================================================
# NEON — Postgres database
# Get at: https://console.neon.tech → your project → Connection string
# Use the POOLED connection string (has "-pooler" in the hostname)
# ============================================================
DATABASE_URL=postgresql://user:pass@host-pooler.region.aws.neon.tech/nexusshorts?sslmode=require

# Direct (non-pooled) connection — only needed for migrations
DIRECT_DATABASE_URL=postgresql://user:pass@host.region.aws.neon.tech/nexusshorts?sslmode=require
